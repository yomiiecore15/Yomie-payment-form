# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- NOTIFICATION & SHEET DB SERVER-SIDE INTEGRATIONS ---
# Google Apps Script Web App URL for Sheets logging
APPS_SCRIPT_URL=""

# LINE Messaging API Channel Access Token
LINE_CHANNEL_ACCESS_TOKEN=""

# LINE Messaging API Group ID, Room ID, or User ID to receive messages
LINE_GROUP_ID=""

# Legacy LINE Notify Token (deprecated - kept as fallback)
LINE_TOKEN=""

# SMTP sender Gmail address for order summaries
SMTP_USER=""

# SMTP Gmail 16-character App Password (requires 2FA on Google Account)
SMTP_PASS=""
